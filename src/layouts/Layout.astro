---
import "../styles/global.css";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import SpeedInsights from "@vercel/speed-insights/astro";

const {
  pageTitle = "Juan Carlos Torres | Full Stack Developer",
  description = "Portfolio de Juan Carlos Torres, desarrollador Full Stack especializado en React y Node.js.",
  ogimage = {
    url: "/images/imagedefault.webp",
    alt: "Portfolio de Juan Carlos Torres",
  },
} = Astro.props;

const siteUrl = new URL(Astro.url).origin;
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
---
<html lang="es" class="dark:bg-[#0E0E11] bg-mint-50/5 font-montserrat scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogimage.url} />
    <meta property="og:image:alt" content={ogimage.alt} />
    <meta property="og:type" content="website" />

    <meta name="theme-color" content="#0E0E11" />

    <!-- Favicon -->
    <link rel="icon" href="/favicon-32x32.png" />
  </head>

  <body class="overflow-x-hidden">
    <SpeedInsights />

    <Header />

    <main class="min-h-[85vh]">
      <slot />
    </main>

    <Footer />

    <script>
      import "../scripts/menu.js";
    </script>
  </body>
</html>